{
  "name": "test",
  "description": "Run tests for the BD Library Manager project",
  "commands": [
    {
      "name": "test",
      "description": "Run all tests",
      "command": "source .venv/bin/activate && python -m pytest",
      "args": [
        {
          "name": "module",
          "description": "Specific test module to run (optional)",
          "type": "string",
          "default": ""
        },
        {
          "name": "verbose",
          "description": "Run tests in verbose mode",
          "type": "boolean",
          "default": false
        },
        {
          "name": "coverage",
          "description": "Run tests with coverage reporting",
          "type": "boolean",
          "default": false
        },
        {
          "name": "last_failed",
          "description": "Run last failed tests first",
          "type": "boolean",
          "default": false
        }
      ]
    }
  ]
}